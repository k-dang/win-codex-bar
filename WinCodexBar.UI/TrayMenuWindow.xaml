<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinCodexBar.UI.TrayMenuWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Tray Menu">

    <Grid x:Name="RootGrid"
          KeyDown="RootGrid_KeyDown"
          IsTabStop="True"
          Background="{StaticResource TrayMenuBackgroundBrush}">
        <Border x:Name="MenuCard" Style="{StaticResource TrayMenuCardStyle}">
            <StackPanel x:Name="MenuItemsHost" Spacing="0" />
        </Border>
    </Grid>
</Window>
