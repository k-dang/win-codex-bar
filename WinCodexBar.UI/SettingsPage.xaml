<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCodexBar.UI.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Height="40"
              Background="Transparent"
              Padding="20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Settings"
                       Style="{StaticResource AppTitleTextStyle}"
                       FontSize="16"
                       LineHeight="20"
                       VerticalAlignment="Center"/>

            <Border x:Name="TitleBarDragRegion" Grid.Column="1" Background="Transparent"/>
            <Border x:Name="TitleBarRightInset" Grid.Column="2" Background="Transparent" Width="0"/>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent">
            <Grid Padding="20" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource AppHeaderCardStyle}">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="2">
                            <TextBlock Text="Settings" Style="{StaticResource AppSectionHeaderStyle}"/>
                            <TextBlock Text="Manage refresh and provider sources" Style="{StaticResource AppSubtleTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="Cancel" Style="{StaticResource AppGhostButtonStyle}" Click="Cancel_Click"/>
                            <Button Content="Save" Style="{StaticResource AppPrimaryButtonStyle}" Click="Save_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Refresh Interval (minutes)" Style="{StaticResource AppSubtleTextStyle}"/>
                            <NumberBox x:Name="SettingsRefreshMinutesBox" Minimum="1" Maximum="120" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding ProviderEditors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding SettingsTitle}" Style="{StaticResource AppSectionHeaderStyle}"/>
                                        <CheckBox Content="{Binding EnabledLabel}" IsChecked="{Binding IsEnabled, Mode=TwoWay}"/>
                                        <TextBlock Text="{Binding SourceLabel}" Style="{StaticResource AppSubtleTextStyle}"/>
                                        <ComboBox ItemsSource="{Binding SourceOptions}" SelectedIndex="{Binding SelectedSourceIndex, Mode=TwoWay}"/>
                                        <TextBlock Text="{Binding CookieSourceLabel}"
                                                   Style="{StaticResource AppSubtleTextStyle}"
                                                   Visibility="{Binding CookieControlsVisibility}"/>
                                        <ComboBox ItemsSource="{Binding CookieSourceOptions}"
                                                  SelectedIndex="{Binding SelectedCookieSourceIndex, Mode=TwoWay}"
                                                  Visibility="{Binding CookieControlsVisibility}"/>
                                        <TextBox Text="{Binding CookieHeader, Mode=TwoWay}"
                                                 PlaceholderText="{Binding CookieHeaderPlaceholder}"
                                                 Visibility="{Binding CookieControlsVisibility}"
                                                 IsEnabled="{Binding IsCookieHeaderEditable}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>

